<?php
/**
 * Backorder ETA badge — product detail page, Hyvä Theme variant.
 *
 * Tailwind utility classes + inline SVG, with dark-mode and reduced-motion
 * variants. The corresponding Luma template lives in product/eta-badge.phtml.
 *
 * @var \ETechFlow\BackorderEtaDisplay\Block\Product\EtaBadge $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isVisible()) {
    return;
}

$style = $block->getBadgeStyle();

$styleMap = [
    'warning' => [
        'container' => 'bg-amber-50 text-amber-900 border-amber-500 '
            . 'dark:bg-amber-900/20 dark:text-amber-200 dark:border-amber-400',
        'icon'      => 'text-amber-600 dark:text-amber-300',
    ],
    'info' => [
        'container' => 'bg-blue-50 text-blue-900 border-blue-600 '
            . 'dark:bg-blue-900/20 dark:text-blue-200 dark:border-blue-400',
        'icon'      => 'text-blue-600 dark:text-blue-300',
    ],
    'neutral' => [
        'container' => 'bg-slate-100 text-slate-700 border-slate-500 '
            . 'dark:bg-slate-700/30 dark:text-slate-200 dark:border-slate-400',
        'icon'      => 'text-slate-600 dark:text-slate-300',
    ],
];

$classes = $styleMap[$style] ?? $styleMap['neutral'];
?>
<div x-data="{ show: false }"
     x-init="$nextTick(() => show = true)"
     x-cloak
     class="etechflow-eta-badge inline-block my-2">
    <div x-show="show"
         x-transition:enter="motion-safe:transition motion-safe:ease-out motion-safe:duration-200"
         x-transition:enter-start="motion-safe:opacity-0 motion-safe:-translate-y-1"
         x-transition:enter-end="motion-safe:opacity-100 motion-safe:translate-y-0"
         class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-semibold leading-snug rounded border-l-4 shadow-sm <?= $escaper->escapeHtmlAttr($classes['container']) ?>"
         role="status"
         aria-label="<?= $escaper->escapeHtmlAttr($block->getDisplayText()) ?>">
        <!-- Truck / shipping icon (Heroicons outline) -->
        <svg class="w-4 h-4 flex-shrink-0 <?= $escaper->escapeHtmlAttr($classes['icon']) ?>"
             fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M13 16V5a1 1 0 00-1-1H4a1 1 0 00-1 1v11h2m11 0h-6m4 0V8h3.28a1 1 0 01.95.68l1.72 5.32V16h-1.5"/>
        </svg>
        <span><?= $escaper->escapeHtml($block->getDisplayText()) ?></span>
    </div>
</div>
