<?php
/**
 * Backorder ETA summary — shopping cart page, Hyvä Theme variant.
 *
 * Tailwind utility classes + inline SVG; dark-mode and reduced-motion variants.
 * Uses aria-live="polite" so screen readers announce delivery changes when
 * the cart re-renders. The Luma template lives in cart/eta-summary.phtml.
 *
 * @var \ETechFlow\BackorderEtaDisplay\Block\Cart\EtaSummary $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isVisible()) {
    return;
}

$style   = $block->getBadgeStyle();
$entries = $block->getBackorderEntries();

$styleMap = [
    'warning' => [
        'container' => 'bg-amber-50 text-amber-900 border-amber-500 '
            . 'dark:bg-amber-900/20 dark:text-amber-200 dark:border-amber-400',
        'icon'      => 'text-amber-600 dark:text-amber-300',
    ],
    'info' => [
        'container' => 'bg-blue-50 text-blue-900 border-blue-600 '
            . 'dark:bg-blue-900/20 dark:text-blue-200 dark:border-blue-400',
        'icon'      => 'text-blue-600 dark:text-blue-300',
    ],
    'neutral' => [
        'container' => 'bg-slate-100 text-slate-700 border-slate-500 '
            . 'dark:bg-slate-700/30 dark:text-slate-200 dark:border-slate-400',
        'icon'      => 'text-slate-600 dark:text-slate-300',
    ],
];

$classes = $styleMap[$style] ?? $styleMap['neutral'];
?>
<div x-data="{ show: false }"
     x-init="$nextTick(() => show = true)"
     x-cloak
     x-show="show"
     x-transition:enter="motion-safe:transition motion-safe:ease-out motion-safe:duration-300"
     x-transition:enter-start="motion-safe:opacity-0 motion-safe:-translate-y-1"
     x-transition:enter-end="motion-safe:opacity-100 motion-safe:translate-y-0"
     class="etechflow-eta-summary mb-4 px-4 py-3 rounded-md border-l-4 text-sm leading-relaxed shadow-sm <?= $escaper->escapeHtmlAttr($classes['container']) ?>"
     role="status"
     aria-live="polite"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Estimated delivery times')) ?>">
    <div class="flex items-start gap-3">
        <!-- Clock icon (Heroicons outline) -->
        <svg class="w-5 h-5 flex-shrink-0 mt-0.5 <?= $escaper->escapeHtmlAttr($classes['icon']) ?>"
             fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="flex-1 min-w-0">
            <strong class="block font-bold text-base mb-2">
                <?= $escaper->escapeHtml(__('Estimated delivery times')) ?>
            </strong>
            <ul class="space-y-1">
                <?php foreach ($entries as $entry): ?>
                    <li class="flex justify-between gap-3 border-t border-current/10 pt-1 first:border-t-0 first:pt-0">
                        <span class="font-medium flex-1 truncate"><?= $escaper->escapeHtml($entry['name']) ?></span>
                        <span class="font-semibold flex-shrink-0 opacity-90 whitespace-nowrap">
                            <?= $escaper->escapeHtml($entry['eta']) ?>
                        </span>
                    </li>
                <?php endforeach; ?>
            </ul>
        </div>
    </div>
</div>
