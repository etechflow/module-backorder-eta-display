<?php
/**
 * Backorder ETA summary on the shopping cart page.
 *
 * @var \ETechFlow\BackorderEtaDisplay\Block\Cart\EtaSummary $block
 * @var \Magento\Framework\Escaper $escaper
 */
if (!$block->isVisible()) {
    return;
}

$style   = $block->getBadgeStyle();
$entries = $block->getBackorderEntries();
?>
<div class="etechflow-eta-summary etechflow-eta-summary--<?= $escaper->escapeHtmlAttr($style) ?>"
     role="note"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Estimated delivery times')) ?>">
    <strong class="etechflow-eta-summary__title">
        <?= $escaper->escapeHtml(__('Estimated delivery times')) ?>
    </strong>
    <ul class="etechflow-eta-summary__list">
        <?php foreach ($entries as $entry): ?>
            <li class="etechflow-eta-summary__item">
                <span class="etechflow-eta-summary__name"><?= $escaper->escapeHtml($entry['name']) ?></span>
                <span class="etechflow-eta-summary__eta"><?= $escaper->escapeHtml($entry['eta']) ?></span>
            </li>
        <?php endforeach; ?>
    </ul>
</div>
