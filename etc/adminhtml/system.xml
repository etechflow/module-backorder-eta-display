<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_backorderetadisplay"
                 translate="label" type="text" sortOrder="120"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Backorder ETA Display</label>
            <tab>etechflow</tab>
            <resource>ETechFlow_BackorderEtaDisplay::config</resource>

            <group id="module_status" translate="label" type="text" sortOrder="1"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Module Status</label>
                <frontend_model>ETechFlow\BackorderEtaDisplay\Block\Adminhtml\System\Config\ModuleStatus</frontend_model>
            </group>

            <group id="license" translate="label" type="text" sortOrder="5"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>


                <field id="license_key" translate="label comment" type="text"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[
                        Auto-populated after Stripe purchase. Format: <code>SP-XXXX-XXXX-XXXX-XXXX</code>.<br/>
                        Bound to your domain. <code>www.</code> prefix normalised — one key works for both.
                    ]]></comment>
                </field>

                <field id="portal_url" translate="label comment" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[
                        URL of the eTechFlow license portal. Called by the Magento server to validate
                        SP-XXXX keys and complete Stripe activation.<br/>
                        Example: <code>https://your-tunnel.ngrok-free.dev</code> or your production portal URL.
                    ]]></comment>
                </field>

                <field id="portal_api_url" translate="label comment" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Validation API URL (optional override)</label>
                    <comment><![CDATA[
                        Optional override for the server-to-server validation URL.
                        If blank, the Portal URL above is used.
                    ]]></comment>
                </field>
            </group>

            <group id="payment" translate="label" type="text" sortOrder="7"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Payment (Stripe)</label>
                <comment>Add your Stripe REST API credentials to enable "Select Plan &amp; Pay" on the gate page. Get them at https://dashboard.stripe.com/test/apikeys.</comment>

                <field id="stripe_secret_key" translate="label" type="obscure"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Secret Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[
                        <code>sk_test_...</code> or <code>sk_live_...</code>. Stored encrypted by Magento.
                    ]]></comment>
                </field>

                <field id="stripe_publishable_key" translate="label" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Publishable Key</label>
                    <comment><![CDATA[
                        <code>pk_test_...</code> or <code>pk_live_...</code>. Public — safe to display.
                    ]]></comment>
                </field>

                <field id="stripe_currency" translate="label" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Currency</label>
                    <comment>Three-letter Stripe currency code, lowercase. Default: <code>usd</code>.</comment>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label comment" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="default_eta" translate="label comment" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default Restock Date</label>
                </field>
                <field id="label_prefix" translate="label comment" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Label Prefix (default text only)</label>
                </field>
            </group>

            <group id="display" translate="label" type="text" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Display Locations</label>
                <field id="show_on_product_page" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show on Product Page</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="show_on_cart" translate="label" type="select"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show on Cart Page</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="show_on_checkout" translate="label" type="select"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show on Checkout</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="show_in_order_email" translate="label" type="select"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include in Order Confirmation Email</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="badge_style" translate="label" type="select"
                       sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Badge Style</label>
                    <source_model>ETechFlow\BackorderEtaDisplay\Model\Source\BadgeStyle</source_model>
                </field>
                <field id="hide_if_next_day_eligible" translate="label tooltip" type="select"
                       sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hide PDP Badge When Product is Next Day Eligible</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
