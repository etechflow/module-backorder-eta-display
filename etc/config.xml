<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <etechflow_backorderetadisplay>
            <license>
                <license_key></license_key>
                <production_environment>1</production_environment>
                <portal_url></portal_url>
                <portal_api_url>https://license-service.etechflow.com</portal_api_url>
                <issued_key></issued_key>
                <issued_at>0</issued_at>
                <issued_domain></issued_domain>
                <issued_plan></issued_plan>
                <stripe_session_id></stripe_session_id>
                <revoked>0</revoked>
                <ip_blocked>0</ip_blocked>
            </license>
            <general>
                <enabled>1</enabled>
                <default_eta>5-7 business days</default_eta>
                <label_prefix>Ships in</label_prefix>
            </general>
            <display>
                <show_on_product_page>1</show_on_product_page>
                <show_on_cart>1</show_on_cart>
                <show_on_checkout>1</show_on_checkout>
                <show_in_order_email>1</show_in_order_email>
                <badge_style>warning</badge_style>
            </display>
        </etechflow_backorderetadisplay>
    </default>
</config>
